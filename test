<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>웹 지뢰찾기 - 난이도 추가</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: #f0f0f0;
            margin-top: 30px;
        }
        h1 { margin-bottom: 10px; color: #333; }
        
        .controls {
            margin-bottom: 15px;
            display: flex;
            gap: 15px;
            align-items: center;
        }
        
        select, button {
            padding: 8px 15px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            border-radius: 5px;
            border: 1px solid #ccc;
        }
        button {
            background-color: #4CAF50;
            color: white;
            border: none;
            transition: background-color 0.3s;
        }
        button:hover { background-color: #45a049; }

        .info {
            font-size: 1.1em;
            font-weight: bold;
            margin-bottom: 10px;
            color: #444;
        }

        #game-board {
            display: grid;
            background-color: #bbb;
            padding: 5px;
            border-radius: 5px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            /* 드래그 방지 */
            user-select: none; 
        }
        
        .cell {
            width: 30px;
            height: 30px;
            background-color: #ddd;
            border: 2px outset #eee;
            box-sizing: border-box;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }
        .cell:active:not(.revealed) { border: 2px inset #eee; }
        .cell.revealed { background-color: #fff; border: 1px solid #ccc; cursor: default; }
        .cell.mine { background-color: #ff4d4d; border: 1px solid #ccc; }
        .cell.flag::after { content: '🚩'; font-size: 18px; }
        
        #status { margin: 15px 0; font-size: 1.5em; font-weight: bold; height: 30px; color: #333; }
    </style>
</head>
<body>

    <h1>지뢰찾기</h1>
    
    <div class="controls">
        <select id="difficulty" onchange="changeDifficulty()">
            <option value="easy">초급 (9x9, 지뢰 10개)</option>
            <option value="medium">중급 (16x16, 지뢰 40개)</option>
            <option value="hard">고급 (30x16, 지뢰 99개)</option>
        </select>
        <button onclick="initGame()">게임 재시작</button>
    </div>

    <div class="info">
        남은 지뢰: <span id="mine-count">10</span>
    </div>

    <div id="game-board"></div>
    <div id="status"></div>

    <script>
        // 기본 난이도 설정 (초급)
        let rows = 9;
        let cols = 9;
        let totalMines = 10;
        
        let board = [];
        let gameOver = false;
        let revealedCount = 0;
        let flagCount = 0;

        const boardElement = document.getElementById('game-board');
        const statusElement = document.getElementById('status');
        const mineCountElement = document.getElementById('mine-count');

        // 난이도 변경 함수
        function changeDifficulty() {
            const difficulty = document.getElementById('difficulty').value;
            if (difficulty === 'easy') {
                rows = 9; cols = 9; totalMines = 10;
            } else if (difficulty === 'medium') {
                rows = 16; cols = 16; totalMines = 40;
            } else if (difficulty === 'hard') {
                rows = 16; cols = 30; totalMines = 99;
            }
            initGame();
        }

        // 게임 초기화
        function initGame() {
            // CSS Grid 컬럼 개수 유동적 설정
            boardElement.style.gridTemplateColumns = `repeat(${cols}, 30px)`;
            boardElement.innerHTML = '';
            statusElement.textContent = '';
            board = [];
            gameOver = false;
            revealedCount = 0;
            flagCount = 0;
            mineCountElement.textContent = totalMines;

            // 2차원 배열 생성
            for (let r = 0; r < rows; r++) {
                let row = [];
                for (let c = 0; c < cols; c++) {
                    row.push({ isMine: false, isRevealed: false, isFlagged: false, neighborMines: 0, element: null });
                }
                board.push(row);
            }

            placeMines();
            calculateNeighbors();
            renderBoard();
        }

        // 지뢰 랜덤 배치
        function placeMines() {
            let minesPlaced = 0;
            while (minesPlaced < totalMines) {
                let r = Math.floor(Math.random() * rows);
                let c = Math.floor(Math.random() * cols);
                if (!board[r][c].isMine) {
                    board[r][c].isMine = true;
                    minesPlaced++;
                }
            }
        }

        // 주변 지뢰 개수 계산
        function calculateNeighbors() {
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    if (board[r][c].isMine) continue;
                    let count = 0;
                    for (let dr = -1; dr <= 1; dr++) {
                        for (let dc = -1; dc <= 1; dc++) {
                            let nr = r + dr, nc = c + dc;
                            if (nr >= 0 && nr < rows && nc >= 0 && nc < cols && board[nr][nc].isMine) {
                                count++;
                            }
                        }
                    }
                    board[r][c].neighborMines = count;
                }
            }
        }

        // 화면에 그리기
        function renderBoard() {
            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    const cellEl = document.createElement('div');
                    cellEl.classList.add('cell');
                    
                    // 좌클릭 (열기)
                    cellEl.addEventListener('click', () => revealCell(r, c));
                    
                    // 우클릭 (깃발)
                    cellEl.addEventListener('contextmenu', (e) => {
                        e.preventDefault();
                        toggleFlag(r, c);
                    });

                    board[r][c].element = cellEl;
                    boardElement.appendChild(cellEl);
                }
            }
        }

        // 칸 열기
        function revealCell(r, c) {
            if (gameOver || board[r][c].isRevealed || board[r][c].isFlagged) return;

            const cell = board[r][c];
            cell.isRevealed = true;
            cell.element.classList.add('revealed');
            revealedCount++;

            if (cell.isMine) {
                cell.element.classList.add('mine');
                cell.element.textContent = '💣';
                handleGameOver(false);
                return;
            }

            if (cell.neighborMines > 0) {
                cell.element.textContent = cell.neighborMines;
                // 숫자별 색상 지정
                const colors = ['', 'blue', 'green', 'red', 'purple', 'maroon', 'turquoise', 'black', 'gray'];
                cell.element.style.color = colors[cell.neighborMines];
            } else {
                // 주변 지뢰가 0이면 재귀적으로 열기 (Flood fill)
                for (let dr = -1; dr <= 1; dr++) {
                    for (let dc = -1; dc <= 1; dc++) {
                        let nr = r + dr, nc = c + dc;
                        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
                            revealCell(nr, nc);
                        }
                    }
                }
            }

            checkWin();
        }

        // 깃발 꽂기/해제
        function toggleFlag(r, c) {
            if (gameOver || board[r][c].isRevealed) return;

            const cell = board[r][c];
            if (!cell.isFlagged) {
                if (flagCount < totalMines) {
                    cell.isFlagged = true;
                    cell.element.classList.add('flag');
                    flagCount++;
                }
            } else {
                cell.isFlagged = false;
                cell.element.classList.remove('flag');
                flagCount--;
            }
            mineCountElement.textContent = totalMines - flagCount;
        }

        // 승리 조건 체크
        function checkWin() {
            if (revealedCount === (rows * cols) - totalMines) {
                handleGameOver(true);
            }
        }

        // 게임 종료 처리
        function handleGameOver(isWin) {
            gameOver = true;
            if (isWin) {
                statusElement.textContent = '🎉 승리했습니다! 🎉';
                statusElement.style.color = 'green';
            } else {
                statusElement.textContent = '💥 지뢰를 밟았습니다! 💥';
                statusElement.style.color = 'red';
                // 패배 시 숨겨진 모든 지뢰 공개
                for (let r = 0; r < rows; r++) {
                    for (let c = 0; c < cols; c++) {
                        if (board[r][c].isMine && !board[r][c].isFlagged) {
                            board[r][c].element.classList.add('revealed', 'mine');
                            board[r][c].element.textContent = '💣';
                        }
                    }
                }
            }
        }

        // 페이지 로드 시 게임 시작
        window.onload = initGame;
    </script>
</body>
</html>
